# Copy this file to `.env.local` and adjust as needed.
# Only variables prefixed with VITE_ are exposed to the client bundle.
# All variables are validated at startup in `src/config/env.ts` — add new ones there.

# Base URL for the API client (src/lib/api-client.ts).
# With MSW mocking on, requests to this path are intercepted in the browser.
VITE_API_URL=/api

# Toggle the MSW mock API in development ("true" | "false").
# Run `npm run msw:init` once before first use.
VITE_ENABLE_API_MOCKING=true

# App title (read in src/config/env.ts, used in index.html-driven metadata).
VITE_APP_TITLE=React Template
