{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write --ignore-unknown ."
          },
          {
            "type": "command",
            "command": "npx tsc -b"
          }
        ]
      }
    ]
  }
}
